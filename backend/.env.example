# Home Assistant
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your_long_lived_token_here
HA_GATE_ENTITY=switch.your_gate_entity

# Frigate NVR
FRIGATE_URL=http://192.168.1.x:5000
FRIGATE_CAMERA=your_camera_name

# Camera PTZ (ONVIF)
CAMERA_IP=192.168.1.x
CAMERA_USER=admin
CAMERA_PASS=your_password
CAMERA_PORT=80
PTZ_PRESET_RING=4
PTZ_PRESET_IDLE=1
# Preset selezionabili dall'app: "Nome:token,Nome:token"
PTZ_PRESETS=Campanello:4,Vista 2:2,Panoramica:1

# App
APP_HOST=0.0.0.0
APP_PORT=8000
RING_TIMEOUT=120
PUBLIC_URL=https://your-domain.example.com
