# Copia in frontend/.env e aggiorna con i valori reali
# NON committare frontend/.env

# Password SIP del peer 'webapp' su Asterisk (sip.conf: secret=...)
VITE_SIP_PASSWORD=change_this_to_your_asterisk_webapp_secret

# API key del backend (stessa di backend/.env WEB_API_KEY)
VITE_SIP_API_KEY=your_api_key_here
